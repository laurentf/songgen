# SongGen RunPod — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# ── RunPod ──────────────────────────────────────────────────────────────
RUNPOD_API_KEY=                      # Settings → API Keys (Read/Write on both graphql + ai)
RUNPOD_ENDPOINT_ID=                  # Serverless → your endpoint → ID

# ── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=                        # Project Settings → API → URL
SUPABASE_KEY=                        # Project Settings → API → Secret key
SUPABASE_BUCKET=songs                # Must be PUBLIC (Storage → songs → Make Public)

# ── RunPod Template Env Vars (set in RunPod console, not here) ──────────
# These go in your RunPod serverless TEMPLATE, not in this file:
#
# SUPABASE_URL          = (same as above)
# SUPABASE_KEY          = (same as above)
# SUPABASE_BUCKET       = songs
# USE_LOW_MEM           = false
# SONGGEN_REPO_PATH     = /workspace/SongGeneration
# SONGGEN_CKPT_PATH     = /workspace/songgeneration_v2_large
# SONGGEN_SHARED_CKPT_PATH = /workspace/ckpt
# HF_TOKEN              = (optional, for gated HuggingFace repos)
